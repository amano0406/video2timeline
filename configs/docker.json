{
  "project_name": "timelineforvideo",
  "source_directories": [
    {
      "name": "videos_primary",
      "path": "/data/input/primary",
      "recursive": true
    },
    {
      "name": "videos_secondary",
      "path": "/data/input/secondary",
      "recursive": true
    }
  ],
  "output_root": "/workspace/runs",
  "video_extensions": [
    ".mp4",
    ".mov",
    ".m4v",
    ".avi",
    ".mkv",
    ".webm"
  ],
  "change_detection": {
    "phash_same_threshold": 4,
    "dhash_same_threshold": 6,
    "mean_diff_same_threshold": 0.015,
    "changed_ratio_same_threshold": 0.01,
    "phash_minor_threshold": 12,
    "dhash_minor_threshold": 14,
    "mean_diff_minor_threshold": 0.05,
    "changed_ratio_minor_threshold": 0.05
  },
  "ocr_policy": {
    "run_only_on_change": true,
    "skip_minor_changes": true
  }
}
