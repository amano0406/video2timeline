@page
@model Video2Timeline.Web.Pages.IndexModel
@inject Video2Timeline.Web.Services.LanguageService LanguageService
@inject Video2Timeline.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    var canCreate = Model.SettingsReady && Model.ActiveRun is null;
    var inputsDisabled = !canCreate;
    string L(string key) => Localizer.Get(lang, key);
    string StateLabel(string? value)
    {
        var key = $"state.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }

    string StageLabel(string? value)
    {
        var key = $"stage.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }

    string AccessLabel(string? value)
    {
        var key = $"access.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? L("access.unknown") : label;
    }

    string FormatSize(long valueBytes) => $"{valueBytes / 1024.0 / 1024.0:F1} MB";
    string FormatDuration(double valueSeconds) => $"{valueSeconds / 60.0:F1} {L("units.min")}";

    ViewData["Title"] = L("index.page_title");
}

<section class="space-y-8">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="space-y-2">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">video2timeline v1</p>
            <h1 class="text-3xl font-semibold text-slate-900">@L("index.header.title")</h1>
            <p class="max-w-3xl text-sm leading-7 text-slate-600">@L("index.header.description")</p>
        </div>
    </div>

    <section class="rounded-3xl border @(Model.SettingsReady ? "border-emerald-200 bg-emerald-50" : "border-amber-200 bg-amber-50") p-8 shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="space-y-2">
                <h2 class="text-xl font-semibold @(Model.SettingsReady ? "text-emerald-950" : "text-amber-950")">
                    @L("index.setup.title")
                </h2>
                <p class="text-sm @(Model.SettingsReady ? "text-emerald-900" : "text-amber-900")">
                    @AccessLabel(Model.SettingsSnapshot.AccessState)
                </p>
            </div>
            <a class="inline-flex items-center rounded-full @(Model.SettingsReady ? "bg-emerald-700 hover:bg-emerald-600" : "bg-amber-700 hover:bg-amber-600") px-5 py-3 text-sm font-medium text-white transition"
               href="/settings">
                @L("index.setup.open")
            </a>
        </div>
    </section>

    @if (Model.ActiveRun is not null)
    {
        <section class="rounded-3xl border border-sky-200 bg-sky-50 p-8 shadow-sm">
            <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
                <div class="space-y-3">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">@L("index.active.title")</p>
                        <h2 class="text-2xl font-semibold text-sky-950">@Model.ActiveRun.JobId</h2>
                    </div>
                    <div class="grid gap-3 text-sm text-sky-900 sm:grid-cols-2 xl:grid-cols-4">
                        <div class="rounded-2xl bg-white/70 px-4 py-3">
                            <div class="font-medium text-sky-950">@L("index.active.state")</div>
                            <div class="mt-1">@StateLabel(Model.ActiveRun.State) / @StageLabel(Model.ActiveRun.CurrentStage)</div>
                        </div>
                        <div class="rounded-2xl bg-white/70 px-4 py-3">
                            <div class="font-medium text-sky-950">@L("index.active.progress")</div>
                            <div class="mt-1">@Model.ActiveRun.VideosDone / @Model.ActiveRun.VideosTotal</div>
                        </div>
                        <div class="rounded-2xl bg-white/70 px-4 py-3">
                            <div class="font-medium text-sky-950">@L("index.active.total_size")</div>
                            <div class="mt-1">@FormatSize(Model.ActiveRun.TotalSizeBytes)</div>
                        </div>
                        <div class="rounded-2xl bg-white/70 px-4 py-3">
                            <div class="font-medium text-sky-950">@L("index.active.total_duration")</div>
                            <div class="mt-1">@FormatDuration(Model.ActiveRun.TotalDurationSec)</div>
                        </div>
                    </div>
                </div>
                <a class="inline-flex items-center rounded-full bg-sky-700 px-5 py-3 text-sm font-medium text-white transition hover:bg-sky-600"
                   href="/runs/@Model.ActiveRun.JobId">
                    @L("index.active.open_details")
                </a>
            </div>
        </section>
    }
    else
    {
        <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                <div class="space-y-2">
                    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">@L("index.active.title")</p>
                    <h2 class="text-2xl font-semibold text-slate-900">@L("index.active.none_title")</h2>
                    <p class="text-sm text-slate-600">@L("index.active.none_description")</p>
                </div>
                <a class="inline-flex items-center rounded-full bg-slate-100 px-5 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-200"
                   href="/settings">
                    @L("index.active.review_settings")
                </a>
            </div>
        </section>
    }

    <form method="post" enctype="multipart/form-data" class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm space-y-6">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                @foreach (var error in ViewContext.ModelState.Values.SelectMany(static value => value.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <fieldset class="grid gap-6 lg:grid-cols-2" disabled="@inputsDisabled">
            <section class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
                <div class="space-y-2">
                    <h2 class="text-lg font-semibold text-slate-900">@L("index.form.files.title")</h2>
                    <p class="text-sm text-slate-600">@L("index.form.files.description")</p>
                </div>
                <input asp-for="UploadFiles" type="file" multiple class="mt-4 block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-700" />
            </section>

            <section class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
                <div class="space-y-2">
                    <h2 class="text-lg font-semibold text-slate-900">@L("index.form.directory.title")</h2>
                    <p class="text-sm text-slate-600">@L("index.form.directory.description")</p>
                </div>
                <input asp-for="UploadDirectoryFiles" type="file" multiple webkitdirectory directory class="mt-4 block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-700" />
            </section>
        </fieldset>

        <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            @Model.InfoMessage
        </div>

        <div class="flex flex-wrap gap-3">
            @if (!Model.SettingsReady)
            {
                <a class="rounded-full bg-amber-700 px-5 py-3 text-sm font-medium text-white transition hover:bg-amber-600"
                   href="/settings">
                    @L("index.form.setup_first")
                </a>
            }
            else if (Model.ActiveRun is null)
            {
                <button asp-page-handler="CreateJob"
                        class="rounded-full bg-emerald-600 px-5 py-3 text-sm font-medium text-white transition hover:bg-emerald-500">
                    @L("index.form.start")
                </button>
            }
            else
            {
                <button type="button"
                        disabled
                        class="cursor-not-allowed rounded-full bg-slate-200 px-5 py-3 text-sm font-medium text-slate-500">
                    @L("index.form.another_running")
                </button>
            }
            <a class="rounded-full bg-slate-100 px-5 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-200"
               href="/settings">
                @L("index.form.settings_link")
            </a>
        </div>
    </form>

    <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="mb-4">
            <h2 class="text-xl font-semibold text-slate-900">@L("index.history.title")</h2>
            <p class="text-sm text-slate-500">@L("index.history.description")</p>
        </div>
        <div class="overflow-x-auto">
            @if (Model.RecentRuns.Count == 0)
            {
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-6 text-sm text-slate-600">
                    @L("index.history.empty")
                </div>
            }
            else
            {
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead class="bg-slate-50 text-left text-slate-600">
                        <tr>
                            <th class="px-4 py-3 font-medium">@L("common.run")</th>
                            <th class="px-4 py-3 font-medium">@L("common.state")</th>
                            <th class="px-4 py-3 font-medium">@L("common.progress")</th>
                            <th class="px-4 py-3 font-medium">@L("common.total_size")</th>
                            <th class="px-4 py-3 font-medium">@L("common.total_duration")</th>
                            <th class="px-4 py-3 font-medium">@L("common.updated")</th>
                            <th class="px-4 py-3 font-medium">@L("common.actions")</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var run in Model.RecentRuns)
                        {
                            <tr>
                                <td class="px-4 py-3 font-medium text-slate-900">
                                    <a class="text-sky-700 hover:text-sky-500" href="/runs/@run.JobId">@run.JobId</a>
                                </td>
                                <td class="px-4 py-3 text-slate-700">@StateLabel(run.State) / @StageLabel(run.CurrentStage)</td>
                                <td class="px-4 py-3 text-slate-700">@run.VideosDone / @run.VideosTotal</td>
                                <td class="px-4 py-3 text-slate-600">@FormatSize(run.TotalSizeBytes)</td>
                                <td class="px-4 py-3 text-slate-600">@FormatDuration(run.TotalDurationSec)</td>
                                <td class="px-4 py-3 text-slate-600">@run.UpdatedAt</td>
                                <td class="px-4 py-3">
                                    <div class="flex flex-wrap gap-2">
                                        <a class="rounded-full bg-slate-100 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-200"
                                           href="/runs/@run.JobId">
                                            @L("common.details")
                                        </a>
                                        @if (string.Equals(run.State, "completed", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <a class="rounded-full bg-emerald-100 px-3 py-1.5 text-xs font-medium text-emerald-700 hover:bg-emerald-200"
                                               href="/runs/@run.JobId/download">
                                                @L("common.zip")
                                            </a>
                                        }
                                        <form method="post" asp-page-handler="Delete" class="inline">
                                            <input type="hidden" name="jobId" value="@run.JobId" />
                                            <button class="rounded-full bg-rose-100 px-3 py-1.5 text-xs font-medium text-rose-700 hover:bg-rose-200">
                                                @L("common.delete")
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </section>
</section>
