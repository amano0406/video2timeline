@page "/runs/{jobId}/{mediaId}"
@model Video2Timeline.Web.Pages.Runs.MediaModel
@inject Video2Timeline.Web.Services.LanguageService LanguageService
@inject Video2Timeline.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    ViewData["Title"] = L("media.page_title");
}

<section class="app-page space-y-6">
    <div class="panel page-header">
        <div>
            <p class="eyebrow">@L("media.page_title")</p>
            <h1 class="page-title">@Model.MediaId</h1>
            <p class="page-description">
                @L("media.run"):
                <a class="text-sky-700 hover:text-sky-500" href="/runs/@Model.JobId">@Model.JobId</a>
            </p>
        </div>
        <a class="btn-secondary" href="/jobs">@L("layout.jobs")</a>
    </div>

    <div class="panel timeline-shell">
        <pre class="text-sm leading-7 text-slate-100">@Model.TimelineText</pre>
    </div>
</section>
