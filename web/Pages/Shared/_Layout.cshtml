@inject Video2Timeline.Web.Services.LanguageService LanguageService
@inject Video2Timeline.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(Context.Request);
    var languages = LanguageService.GetSupportedLanguages();
    string L(string key) => Localizer.Get(lang, key);
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - video2timeline</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-slate-100 text-slate-900">
    <header class="border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-4">
            <a href="/" class="text-lg font-semibold tracking-tight text-slate-900">video2timeline</a>
            <nav class="flex items-center gap-3 text-sm">
                <a href="/" class="rounded-full px-4 py-2 text-slate-700 transition hover:bg-slate-100">@L("layout.dashboard")</a>
                <a href="/settings" class="rounded-full px-4 py-2 text-slate-700 transition hover:bg-slate-100">@L("layout.settings")</a>
                <form method="get" action="/set-language" class="ml-2 flex items-center gap-2 rounded-full bg-slate-100 px-3 py-2">
                    <input type="hidden" name="returnUrl" value="@currentUrl" />
                    <label for="lang-switch" class="text-xs font-medium text-slate-600">@L("layout.language")</label>
                    <select id="lang-switch"
                            name="lang"
                            class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs text-slate-700"
                            onchange="this.form.submit()">
                        @foreach (var item in languages)
                        {
                            <option value="@item.Code" selected="@(item.Code == lang)">@item.NativeName</option>
                        }
                    </select>
                </form>
            </nav>
        </div>
    </header>

    <main class="mx-auto max-w-7xl px-6 py-8">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
