@page
@model ErrorModel
@inject Video2Timeline.Web.Services.LanguageService LanguageService
@inject Video2Timeline.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    ViewData["Title"] = L("error.page_title");
}

<section class="space-y-6">
    <div class="rounded-3xl border border-rose-200 bg-white p-8 shadow-sm">
        <h1 class="text-3xl font-semibold text-rose-700">@L("error.page_title")</h1>
        <h2 class="mt-2 text-base text-slate-700">@L("error.subtitle")</h2>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm text-sm text-slate-700">
            <strong>@L("error.request_id"):</strong> <code>@Model.RequestId</code>
        </div>
    }

    <div class="rounded-3xl border border-amber-200 bg-amber-50 p-6 shadow-sm text-sm text-amber-950">
        <h3 class="text-lg font-semibold">@L("error.development_mode")</h3>
        <p class="mt-3">@L("error.development_description")</p>
        <p class="mt-3">@L("error.development_warning")</p>
    </div>
</section>
