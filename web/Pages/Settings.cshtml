@page "/settings"
@model TimelineForVideo.Web.Pages.SettingsModel
@inject TimelineForVideo.Web.Services.LanguageService LanguageService
@inject TimelineForVideo.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    var languages = LanguageService.GetSupportedLanguages();
    string L(string key) => Localizer.Get(lang, key);
    string AccessLabel(string? value)
    {
        var key = $"access.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? L("access.unknown") : label;
    }

    string AccessBadgeClass(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "available" => "status-badge status-badge-neutral",
        "authorized" => "status-badge status-badge-success",
        "token_missing" => "status-badge status-badge-warning",
        "consent_pending" => "status-badge status-badge-warning",
        "unauthorized" => "status-badge status-badge-danger",
        _ => "status-badge status-badge-neutral",
    };

    string FormatSize(long valueBytes)
    {
        if (valueBytes <= 0)
        {
            return "0 MB";
        }

        return valueBytes switch
        {
            >= 1024L * 1024L * 1024L => $"{valueBytes / 1024.0 / 1024.0 / 1024.0:F1} GB",
            _ => $"{valueBytes / 1024.0 / 1024.0:F1} MB",
        };
    }

    string FormatGpuMemory(double valueGiB)
    {
        if (valueGiB <= 0)
        {
            return L("settings.compute_mode.help_unknown_memory");
        }

        return $"{valueGiB:F1} GB";
    }

    var detectedGpuLabel = Model.WorkerCapability.DeviceNames.Count > 0
        ? string.Join(", ", Model.WorkerCapability.DeviceNames)
        : L("settings.compute_mode.help_no_gpu_detected");

    ViewData["Title"] = L("settings.page_title");
}

<section class="app-page space-y-6">
    <header class="panel page-header">
        <div>
            <p class="eyebrow">@L("settings.eyebrow")</p>
            <h1 class="page-title">@L("settings.page_title")</h1>
            <p class="page-description">@L("settings.header.description")</p>
        </div>
    </header>

    @if (!ViewContext.ModelState.IsValid)
    {
        <section class="panel error-panel">
            <ul class="list-disc space-y-1 pl-5">
                @foreach (var error in ViewContext.ModelState.Values.SelectMany(static value => value.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="panel notice-panel">
            @Model.StatusMessage
        </section>
    }

    <div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
        <section class="panel space-y-6">
            <div class="panel subtle-panel">
                <p class="section-title">@L("settings.notice.title")</p>
                <p class="mt-3 text-sm leading-7 text-slate-600">@L("settings.notice.description")</p>
                <div class="mt-4 flex flex-wrap gap-3">
                    <a class="btn-secondary"
                       href="@Model.TokenSettingsUrl"
                       target="_blank"
                       rel="noreferrer">
                        @L("settings.open_token")
                    </a>
                    <a class="btn-secondary"
                       href="@Model.PyannoteModelUrl"
                       target="_blank"
                       rel="noreferrer">
                        @L("settings.open_approval")
                    </a>
                </div>
            </div>

            <div class="panel subtle-panel">
                <div class="mb-4 flex items-center justify-between gap-3">
                    <div>
                        <p class="eyebrow">@L("settings.models.eyebrow")</p>
                        <h2 class="section-title">@L("settings.models.title")</h2>
                    </div>
                </div>
                <div class="table-shell">
                    <table class="app-table">
                        <thead>
                            <tr>
                                <th>@L("settings.models.model")</th>
                                <th>@L("settings.models.purpose")</th>
                                <th>@L("settings.models.access")</th>
                                <th>@L("common.actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var gatedModel in Model.ModelStatuses)
                            {
                                <tr>
                                    <td class="font-medium text-slate-900">@gatedModel.DisplayName</td>
                                    <td>@gatedModel.Purpose</td>
                                    <td>
                                        <span class="@AccessBadgeClass(gatedModel.AccessState)">@AccessLabel(gatedModel.AccessState)</span>
                                    </td>
                                    <td>
                                        @if (gatedModel.RequiresApproval && !string.IsNullOrWhiteSpace(gatedModel.ApprovalUrl))
                                        {
                                            <a class="btn-table" href="@gatedModel.ApprovalUrl" target="_blank" rel="noreferrer">
                                                @L("settings.models.open")
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-sm text-slate-500">@L("settings.models.no_action")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <form method="post" asp-page-handler="Save" class="space-y-5">
                <div class="space-y-2">
                    <p class="eyebrow">@L("settings.language.title")</p>
                    <h2 class="section-title">@L("settings.language.heading")</h2>
                    <p class="text-sm leading-7 text-slate-600">@L("settings.language.description")</p>
                    <div class="pt-2">
                        <label for="language-select" class="mb-2 block text-sm font-medium text-slate-900">@L("layout.language")</label>
                        <select id="language-select" asp-for="UiLanguage" class="form-input w-full">
                            @foreach (var item in languages)
                            {
                                <option value="@item.Code">@item.NativeName</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900" for="token-input">@L("settings.token")</label>
                    <input id="token-input"
                           name="Token"
                           type="password"
                           placeholder="hf_..."
                           class="form-input"
                           spellcheck="false"
                           autocomplete="off" />
                    <p class="text-xs text-slate-500">@L("settings.token_hint")</p>
                </div>

                <div class="space-y-3">
                    <div class="flex items-center gap-2">
                        <div class="text-sm font-medium text-slate-900">@L("settings.compute_mode.title")</div>
                        <details class="group relative">
                            <summary class="flex h-6 w-6 cursor-pointer list-none items-center justify-center rounded-full border border-slate-300 bg-white text-xs font-semibold text-slate-600 transition hover:border-slate-400 hover:text-slate-900">
                                <span aria-hidden="true">?</span>
                                <span class="sr-only">@L("settings.compute_mode.help_label")</span>
                            </summary>
                            <div class="absolute left-0 top-8 z-20 w-80 rounded-2xl border border-slate-200 bg-white p-4 text-xs leading-6 text-slate-600 shadow-2xl shadow-slate-200/70">
                                <p class="font-semibold text-slate-900">@L("settings.compute_mode.help_title")</p>
                                <p class="mt-2">@L("settings.compute_mode.help_intro")</p>
                                <ul class="mt-3 list-disc space-y-1 pl-4">
                                    <li>@L("settings.compute_mode.help_req_nvidia")</li>
                                    <li>@L("settings.compute_mode.help_req_docker")</li>
                                    <li>@L("settings.compute_mode.help_req_high")</li>
                                    <li>@L("settings.compute_mode.help_req_8gb")</li>
                                </ul>
                                <dl class="mt-3 space-y-1 border-t border-slate-100 pt-3">
                                    <div class="flex items-start justify-between gap-3">
                                        <dt class="text-slate-500">@L("settings.compute_mode.help_detected_gpu")</dt>
                                        <dd class="text-right text-slate-900">@detectedGpuLabel</dd>
                                    </div>
                                    <div class="flex items-start justify-between gap-3">
                                        <dt class="text-slate-500">@L("settings.compute_mode.help_detected_memory")</dt>
                                        <dd class="text-right text-slate-900">@FormatGpuMemory(Model.WorkerCapability.MaxGpuMemoryGiB)</dd>
                                    </div>
                                </dl>
                            </div>
                        </details>
                    </div>
                    <p class="text-xs text-slate-500">@L("settings.compute_mode.description")</p>
                    <div class="rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700">
                        @if (Model.WorkerCapability.GpuAvailable && Model.WorkerCapability.DeviceNames.Count > 0)
                        {
                            <span>@string.Format(L("settings.compute_mode.gpu_ready"), string.Join(", ", Model.WorkerCapability.DeviceNames))</span>
                        }
                        else
                        {
                            <span>@L("settings.compute_mode.gpu_unavailable_note")</span>
                        }
                    </div>
                    <div class="grid gap-3 md:grid-cols-2">
                        <label class="flex items-start gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700">
                            <input asp-for="ComputeMode"
                                   type="radio"
                                   value="cpu"
                                   class="mt-1 h-4 w-4 border-slate-300 text-slate-900" />
                            <span>
                                <span class="block font-medium text-slate-900">@L("settings.compute_mode.cpu")</span>
                                <span class="block text-xs text-slate-500">@L("settings.compute_mode.cpu_note")</span>
                            </span>
                        </label>
                        <label class="flex items-start gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700 @(!Model.WorkerCapability.GpuAvailable ? "opacity-60 cursor-not-allowed" : "")">
                            <input asp-for="ComputeMode"
                                   type="radio"
                                   value="gpu"
                                   disabled="@(!Model.WorkerCapability.GpuAvailable)"
                                   class="mt-1 h-4 w-4 border-slate-300 text-slate-900" />
                            <span>
                                <span class="block font-medium text-slate-900">@L("settings.compute_mode.gpu")</span>
                                <span class="block text-xs text-slate-500">@L("settings.compute_mode.gpu_note")</span>
                            </span>
                        </label>
                    </div>
                </div>

                <div class="space-y-3">
                    <div class="text-sm font-medium text-slate-900">@L("settings.processing_quality.title")</div>
                    <p class="text-xs text-slate-500">@L("settings.processing_quality.description")</p>
                    <div class="grid gap-3 md:grid-cols-2">
                        <label class="flex items-start gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700">
                            <input asp-for="ProcessingQuality"
                                   type="radio"
                                   value="standard"
                                   class="mt-1 h-4 w-4 border-slate-300 text-slate-900" />
                            <span>
                                <span class="block font-medium text-slate-900">@L("settings.processing_quality.standard")</span>
                                <span class="block text-xs text-slate-500">@L("settings.processing_quality.standard_note")</span>
                            </span>
                        </label>
                        <label class="flex items-start gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700 @(!Model.CanUseHighQuality ? "opacity-60 cursor-not-allowed" : "")">
                            <input asp-for="ProcessingQuality"
                                   type="radio"
                                   value="high"
                                   disabled="@(!Model.CanUseHighQuality)"
                                   class="mt-1 h-4 w-4 border-slate-300 text-slate-900" />
                            <span>
                                <span class="block font-medium text-slate-900">@L("settings.processing_quality.high")</span>
                                <span class="block text-xs text-slate-500">@L("settings.processing_quality.high_note")</span>
                                @if (!Model.CanUseHighQuality)
                                {
                                    <span class="mt-2 block text-xs text-amber-700">@L("settings.processing_quality.high_unavailable_note")</span>
                                }
                            </span>
                        </label>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-3">
                    <button class="btn-primary">@L("settings.save_button")</button>
                </div>
            </form>
        </section>

        <section class="space-y-6">
            <div class="panel space-y-4">
                <div>
                    <p class="eyebrow">@L("settings.cache.eyebrow")</p>
                    <h2 class="section-title">@L("settings.cache.title")</h2>
                    <p class="mt-2 text-sm leading-7 text-slate-600">@L("settings.cache.description")</p>
                </div>

                <dl class="grid gap-4 text-sm text-slate-700">
                    <div>
                        <dt class="text-slate-500">@L("settings.cache.saved_models")</dt>
                        <dd>@FormatSize(Model.ModelCache.TotalBytes)</dd>
                    </div>
                </dl>

                <form method="post" asp-page-handler="ClearModelCache">
                    <button class="btn-secondary" type="submit">@L("settings.cache.clear_button")</button>
                </form>
            </div>
        </section>
    </div>
</section>
