@page "/settings"
@model Video2Timeline.Web.Pages.SettingsModel
@inject Video2Timeline.Web.Services.LanguageService LanguageService
@inject Video2Timeline.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    string AccessLabel(string? value)
    {
        var key = $"access.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? L("access.unknown") : label;
    }

    ViewData["Title"] = L("settings.page_title");
}

<section class="app-page space-y-6">
    <header class="panel page-header">
        <div>
            <p class="eyebrow">@L("settings.eyebrow")</p>
            <h1 class="page-title">@L("settings.page_title")</h1>
            <p class="page-description">@L("settings.header.description")</p>
        </div>
    </header>

    @if (!ViewContext.ModelState.IsValid)
    {
        <section class="panel error-panel">
            <ul class="list-disc space-y-1 pl-5">
                @foreach (var error in ViewContext.ModelState.Values.SelectMany(static value => value.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="panel notice-panel">
            @Model.StatusMessage
        </section>
    }

    <div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
        <section class="panel space-y-6">
            <div class="grid gap-4 md:grid-cols-3">
                <div class="metric-card">
                    <div class="metric-label">@L("settings.token")</div>
                    <div class="metric-value">@(Model.SetupState.HasToken ? L("settings.saved") : L("settings.not_saved"))</div>
                </div>
                <div class="metric-card">
                    <div class="metric-label">@L("settings.consent")</div>
                    <div class="metric-value">@(Model.SetupState.TermsConfirmed ? L("settings.confirmed") : L("settings.not_confirmed"))</div>
                </div>
                <div class="metric-card">
                    <div class="metric-label">@L("settings.model_access")</div>
                    <div class="metric-value text-base">@AccessLabel(Model.Snapshot.AccessState)</div>
                </div>
            </div>

            <div class="panel subtle-panel">
                <p class="section-title">@L("settings.notice.title")</p>
                <p class="mt-3 text-sm leading-7 text-slate-600">@L("settings.notice.description")</p>
                <div class="mt-4 flex flex-wrap gap-3">
                    <a class="btn-secondary"
                       href="@Model.TokenSettingsUrl"
                       target="_blank"
                       rel="noreferrer">
                        @L("settings.open_token")
                    </a>
                    <a class="btn-secondary"
                       href="@Model.PyannoteModelUrl"
                       target="_blank"
                       rel="noreferrer">
                        @L("settings.open_approval")
                    </a>
                </div>
            </div>

            <form method="post" asp-page-handler="Save" class="space-y-5">
                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900" for="token-input">@L("settings.token")</label>
                    <input id="token-input"
                           name="Token"
                           type="password"
                           value="@Model.Token"
                           placeholder="hf_..."
                           class="form-input"
                           spellcheck="false"
                           autocomplete="off" />
                    <p class="text-xs text-slate-500">@L("settings.token_hint")</p>
                </div>

                <label class="flex items-start gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700">
                    <input asp-for="TermsConfirmed"
                           type="checkbox"
                           class="mt-1 h-4 w-4 rounded border-slate-300 text-slate-900" />
                    <span>@L("settings.terms_label")</span>
                </label>

                <div class="space-y-3">
                    <div class="text-sm font-medium text-slate-900">@L("settings.compute_mode.title")</div>
                    <p class="text-xs text-slate-500">@L("settings.compute_mode.description")</p>
                    <div class="grid gap-3 md:grid-cols-2">
                        <label class="flex items-start gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700">
                            <input asp-for="ComputeMode"
                                   type="radio"
                                   value="cpu"
                                   class="mt-1 h-4 w-4 border-slate-300 text-slate-900" />
                            <span>
                                <span class="block font-medium text-slate-900">@L("settings.compute_mode.cpu")</span>
                                <span class="block text-xs text-slate-500">@L("settings.compute_mode.cpu_note")</span>
                            </span>
                        </label>
                        <label class="flex items-start gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700">
                            <input asp-for="ComputeMode"
                                   type="radio"
                                   value="gpu"
                                   class="mt-1 h-4 w-4 border-slate-300 text-slate-900" />
                            <span>
                                <span class="block font-medium text-slate-900">@L("settings.compute_mode.gpu")</span>
                                <span class="block text-xs text-slate-500">@L("settings.compute_mode.gpu_note")</span>
                            </span>
                        </label>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-3">
                    <button class="btn-primary">@L("settings.save_button")</button>
                </div>
            </form>
        </section>

        <section class="panel space-y-4">
            <div>
                <p class="eyebrow">@L("settings.appearance.eyebrow")</p>
                <h2 class="section-title">@L("settings.appearance.title")</h2>
                <p class="mt-2 text-sm leading-7 text-slate-600">@L("settings.appearance.description")</p>
            </div>

            <div class="theme-picker">
                <label class="theme-option">
                    <input type="radio" name="theme-mode" value="workbench" checked />
                    <span class="font-medium text-slate-900">@L("settings.appearance.workbench")</span>
                    <div class="theme-preview">
                        <span></span><span></span><span></span><span></span>
                    </div>
                </label>
                <label class="theme-option">
                    <input type="radio" name="theme-mode" value="classic" />
                    <span class="font-medium text-slate-900">@L("settings.appearance.classic")</span>
                    <div class="theme-preview">
                        <span style="background:#f8fafc"></span>
                        <span style="background:#0f172a"></span>
                        <span style="background:#cbd5e1"></span>
                        <span style="background:#f8fafc"></span>
                    </div>
                </label>
            </div>
        </section>
    </div>
</section>

@section Scripts
{
    <script>
        (() => {
            const storageKey = "video2timeline-theme";
            const radios = Array.from(document.querySelectorAll("input[name='theme-mode']"));
            const applyTheme = (value) => {
                document.documentElement.dataset.appTheme = value;
                localStorage.setItem(storageKey, value);
            };

            const initial = localStorage.getItem(storageKey) || document.documentElement.dataset.appTheme || "workbench";
            const activeRadio = radios.find((radio) => radio.value === initial);
            if (activeRadio) {
                activeRadio.checked = true;
            }
            applyTheme(initial);

            radios.forEach((radio) => {
                radio.addEventListener("change", () => {
                    if (radio.checked) {
                        applyTheme(radio.value);
                    }
                });
            });
        })();
    </script>
}
